  FCM
}

enum AppSurface {
  CUSTOMER_APP
  RIDER_APP
  VENDOR_DASHBOARD
  ADMIN_PORTAL
}

enum UtilityServiceType {
  AIRTIME
  DATA
  ELECTRICITY
  CABLE_TV
}

enum UtilityTransactionStatus {
  DRAFT
  PENDING
  PROCESSING
  SUCCESSFUL
  FAILED
  CANCELLED
}

enum TaxiApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  CHANGES_REQUESTED
  PROVISIONALLY_APPROVED
  APPROVED
  REJECTED
}

enum TaxiWaitlistStatus {
  SUBMITTED
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
}

enum TaxiVehicleType {
  SEDAN
  SUV
  MINI_BUS
  TRICYCLE
  OTHER
}

enum TaxiVehicleOwnership {
  OWNER
  LEASED
  COMPANY_ASSIGNED
  OTHER
}

enum DeliveryCaptainApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  CHANGES_REQUESTED
  PROVISIONALLY_APPROVED
  APPROVED
  REJECTED
}

enum DeliveryCaptainVehicleType {
  MOTORCYCLE
  BICYCLE
  TRICYCLE
  CAR
  VAN
  OTHER
}

enum TaxiDriverProfileStatus {
  PENDING_ACTIVATION
  ACTIVE_TEST
  SUSPENDED
  DEACTIVATED
}

enum TaxiTripStatus {
  REQUESTED
  DRIVER_ASSIGNED
  ACCEPTED
  ARRIVED_PICKUP
  STARTED
  ARRIVED_DESTINATION
  COMPLETED
  CANCELLED_BY_CUSTOMER
  CANCELLED_BY_DRIVER
  CANCELLED_BY_ADMIN
  EXPIRED
}

enum TaxiTripActorType {
  CUSTOMER
  DRIVER
  ADMIN
  SYSTEM
}

model User {
  id                                  String                       @id @default(uuid()) @db.Uuid
  fullName                            String
  phoneNumber                         String                       @unique
  email                               String?                      @unique
  passwordHash                        String
  role                                UserRole
  adminRole                           AdminRole?
  accountStatus                       AccountStatus                @default(PENDING)
  phoneVerified                       Boolean                      @default(false)
  emailVerified                       Boolean                      @default(false)
  lastLoginAt                         DateTime?
  deletedAt                           DateTime?
  createdAt                           DateTime                     @default(now())
  updatedAt                           DateTime                     @updatedAt
  customerProfile                     CustomerProfile?
  vendor                              Vendor?
  rider                               Rider?
  addresses                           Address[]
  notifications                       Notification[]
  deviceTokens                        DeviceToken[]
  refreshTokens                       RefreshToken[]
  statusChanges                       OrderStatusHistory[]         @relation("StatusChangedBy")
  verifiedDocuments                   RiderDocument[]              @relation("DocumentVerifiedBy")
  assignedTickets                     SupportTicket[]              @relation("TicketAssignedAdmin")
  ticketMessages                      SupportTicketMessage[]
  adminAuditLogs                      AdminAuditLog[]
  assignedServiceRequests             ServiceProviderRequest[]     @relation("ServiceProviderRequestAssignedBy")
  reviewedServiceProviderApplications ServiceProviderApplication[] @relation("ServiceProviderApplicationReviewedBy")
  createdPromoCodes                   PromoCode[]                  @relation("PromoCreatedBy")
  otpVerifications                    OtpVerification[]
  verifiedPayoutAccounts              VendorPayoutAccount[]        @relation("PayoutVerifiedBy")
  taxiDriverApplications              TaxiDriverApplication[]      @relation("TaxiApplicant")
  reviewedTaxiApplications            TaxiDriverApplication[]      @relation("TaxiReviewedBy")
  taxiDriverProfiles                  TaxiDriverProfile[]
  createdWalletLedgerEntries          CustomerWalletLedgerEntry[]  @relation("WalletLedgerEntryCreatedByAdmin")
  createdReferralRewardRules          CustomerReferralRewardRule[] @relation("ReferralRewardRuleCreatedBy")

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?   @db.Uuid
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt, expiresAt])
  @@map("refresh_tokens")
}

model TaxiDriverApplication {
  id                   String                @id @default(uuid()) @db.Uuid
  applicationReference String                @unique
  applicantUserId      String?               @db.Uuid
  fullName             String
  phoneNumber          String
  email                String?
  city                 String
  state                String
  address              String?
  driverLicenceNumber  String?
  driverLicenceExpiry  DateTime?
  vehicleMake          String?
  vehicleModel         String?
  vehicleYear          Int?
  vehicleColour        String?
  vehiclePlateNumber   String?
  vehicleType          TaxiVehicleType?
  vehicleOwnership     TaxiVehicleOwnership?
  notes                String?
  status               TaxiApplicationStatus @default(SUBMITTED)
  adminNote            String?
  applicantVisibleNote String?
  reviewedByAdminId    String?               @db.Uuid
  reviewedAt           DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  applicant            User?                 @relation("TaxiApplicant", fields: [applicantUserId], references: [id])
  reviewedByAdmin      User?                 @relation("TaxiReviewedBy", fields: [reviewedByAdminId], references: [id])
  driverProfile        TaxiDriverProfile?

  @@index([status, createdAt])
  @@index([phoneNumber])
  @@index([city, state])
  @@map("taxi_driver_applications")
}

model DeliveryCaptainApplication {
  id                   String                           @id @default(uuid()) @db.Uuid
  applicationReference String                           @unique
  fullName             String
  phoneNumber          String
  email                String?
  city                 String
  state                String
  address              String
  preferredZone        String?
  vehicleType          DeliveryCaptainVehicleType
  vehiclePlateNumber   String?
  riderExperience      String?
  guarantorName        String
  guarantorPhone       String
  notes                String?
  status               DeliveryCaptainApplicationStatus @default(SUBMITTED)
  adminNote            String?
  applicantVisibleNote String?
  reviewedAt           DateTime?
  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt

  @@index([status, createdAt])
  @@index([phoneNumber])
  @@index([city, state])
  @@map("delivery_captain_applications")
}

model TaxiWaitlistEntry {
  id          String             @id @default(uuid()) @db.Uuid
  fullName    String
  phoneNumber String
  email       String?
  city        String
  state       String
  pickupArea  String?
  note        String?
  status      TaxiWaitlistStatus @default(SUBMITTED)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([phoneNumber])
  @@index([city, state])
  @@map("taxi_waitlist_entries")
}

model TaxiDriverProfile {
  id                 String                  @id @default(uuid()) @db.Uuid
  userId             String?                 @unique @db.Uuid
  applicationId      String?                 @unique @db.Uuid
  fullName           String
  phoneNumber        String
  city               String
  state              String
  vehicleMake        String?
  vehicleModel       String?
  vehicleYear        Int?
  vehicleColour      String?
  vehiclePlateNumber String?
  vehicleType        TaxiVehicleType?
  status             TaxiDriverProfileStatus @default(PENDING_ACTIVATION)
  isAvailableForTaxi Boolean                 @default(false)
  lastKnownLatitude  Decimal?                @db.Decimal(10, 7)
  lastKnownLongitude Decimal?                @db.Decimal(10, 7)
  lastSeenAt         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User?                   @relation(fields: [userId], references: [id])
  application        TaxiDriverApplication?  @relation(fields: [applicationId], references: [id])
  trips              TaxiTrip[]

  @@index([status, isAvailableForTaxi])
  @@index([city, state])
  @@index([phoneNumber])
  @@map("taxi_driver_profiles")
}

model TaxiTrip {
  id                     String             @id @default(uuid()) @db.Uuid
  tripReference          String             @unique
  customerId             String             @db.Uuid
  driverProfileId        String?            @db.Uuid
  pickupAddress          String
  pickupLatitude         Decimal?           @db.Decimal(10, 7)
  pickupLongitude        Decimal?           @db.Decimal(10, 7)
  destinationAddress     String
  destinationLatitude    Decimal?           @db.Decimal(10, 7)
  destinationLongitude   Decimal?           @db.Decimal(10, 7)
  estimatedDistanceKm    Decimal?           @db.Decimal(8, 2)
  estimatedDurationMin   Int?
  estimatedFareKobo      Int
  finalFareKobo          Int?
  status                 TaxiTripStatus     @default(REQUESTED)
  tripPinHash            String?
  tripPinLastFour        String?
  cancellationReason     String?
  customerNote           String?
  driverNote             String?
  isTestMode             Boolean            @default(true)
  requestedAt            DateTime           @default(now())
  acceptedAt             DateTime?
  arrivedAtPickupAt      DateTime?
  startedAt              DateTime?
  arrivedAtDestinationAt DateTime?
  completedAt            DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  customer               CustomerProfile    @relation(fields: [customerId], references: [id])
  driverProfile          TaxiDriverProfile? @relation(fields: [driverProfileId], references: [id])
  events                 TaxiTripEvent[]

  @@index([customerId, createdAt])
  @@index([driverProfileId, status])
  @@index([status, createdAt])
  @@map("taxi_trips")
}

model TaxiTripEvent {
  id        String            @id @default(uuid()) @db.Uuid
  tripId    String            @db.Uuid
  actorType TaxiTripActorType
  actorId   String?           @db.Uuid
  eventType String
  note      String?
  metadata  Json?
  createdAt DateTime          @default(now())
  trip      TaxiTrip          @relation(fields: [tripId], references: [id])

  @@index([tripId, createdAt])
  @@index([actorType, createdAt])
  @@map("taxi_trip_events")
}

model OtpVerification {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  purpose    String    @default("PHONE_VERIFICATION")
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId, purpose, createdAt])
  @@map("otp_verifications")
}

model CustomerProfile {
  id                      String                      @id @default(uuid()) @db.Uuid
  userId                  String                      @unique @db.Uuid
  referralCode            String                      @unique
  referredBy              String?                     @db.Uuid
  loyaltyBalance          Decimal                     @default(0) @db.Decimal(12, 2)
  totalOrders             Int                         @default(0)
  averageRating           Decimal?                    @db.Decimal(3, 2)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  user                    User                        @relation(fields: [userId], references: [id])
  referrer                CustomerProfile?            @relation("CustomerReferrals", fields: [referredBy], references: [id])
  referrals               CustomerProfile[]           @relation("CustomerReferrals")
  orders                  Order[]
  payments                Payment[]
  supportTickets          SupportTicket[]
  promoCodeUsages         PromoCodeUsage[]
  utilityTransactions     UtilityTransaction[]
  taxiTrips               TaxiTrip[]
  serviceProviderRequests ServiceProviderRequest[]
  wallet                  CustomerWallet?
  walletLedgerEntries     CustomerWalletLedgerEntry[]
  referralProfile         CustomerReferralProfile?
  referralsMade           CustomerReferral[]          @relation("CustomerReferralReferredBy")
  referralReceived        CustomerReferral?           @relation("CustomerReferralReferredCustomer")

  @@map("customer_profiles")
}

model UtilityProvider {
  id           String               @id @default(uuid()) @db.Uuid
  type         UtilityServiceType
  name         String
  code         String               @unique
  isActive     Boolean              @default(true)
  metadata     Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  products     UtilityProduct[]
  transactions UtilityTransaction[]

  @@index([type, isActive])
  @@map("utility_providers")
}

model UtilityProduct {
  id            String               @id @default(uuid()) @db.Uuid
  providerId    String               @db.Uuid
  type          UtilityServiceType
  name          String
  code          String               @unique
  amountKobo    Int?
  minAmountKobo Int?
  maxAmountKobo Int?
  isActive      Boolean              @default(true)
  metadata      Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  provider      UtilityProvider      @relation(fields: [providerId], references: [id])
  transactions  UtilityTransaction[]

  @@index([providerId, type, isActive])
  @@map("utility_products")
}

model UtilityTransaction {
  id                 String                   @id @default(uuid()) @db.Uuid
  reference          String                   @unique
  customerId         String                   @db.Uuid
  serviceType        UtilityServiceType
  providerId         String                   @db.Uuid
  productId          String?                  @db.Uuid
  amountKobo         Int
  convenienceFeeKobo Int                      @default(0)
  totalKobo          Int
  recipient          String
  recipientName      String?
  status             UtilityTransactionStatus @default(PENDING)
  providerStatus     String?
  providerReference  String?
  mockToken          String?
  customerNote       String?
  failureReason      String?
  metadata           Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  completedAt        DateTime?
  customer           CustomerProfile          @relation(fields: [customerId], references: [id])
  provider           UtilityProvider          @relation(fields: [providerId], references: [id])
  product            UtilityProduct?          @relation(fields: [productId], references: [id])

  @@index([customerId, createdAt])
  @@index([serviceType, status, createdAt])
  @@index([providerId, createdAt])
  @@map("utility_transactions")
}

model Address {
  id                      String                   @id @default(uuid()) @db.Uuid
  userId                  String                   @db.Uuid
  label                   String
  addressLine             String
  city                    String
  state                   String
  country                 String                   @default("Nigeria")
  latitude                Decimal?                 @db.Decimal(10, 7)
  longitude               Decimal?                 @db.Decimal(10, 7)
  deliveryNote            String?
  isDefault               Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  user                    User                     @relation(fields: [userId], references: [id])
  pickupOrders            Order[]                  @relation("PickupAddress")
  deliveryOrders          Order[]                  @relation("DeliveryAddress")
  serviceProviderRequests ServiceProviderRequest[] @relation("ServiceRequestAddress")

  @@index([userId])
  @@map("addresses")
}

model ServiceProviderRequest {
  id                  String                       @id @default(uuid()) @db.Uuid
  requestNumber       String                       @unique
  customerId          String                       @db.Uuid
  assignedProviderId  String?                      @db.Uuid
  assignedByAdminId   String?                      @db.Uuid
  serviceType         ServiceProviderType
  serviceLabel        String
  serviceAddressId    String                       @db.Uuid
  description         String
  contactPhone        String
  preferredDate       String?
  preferredTimeWindow String?
  customerNote        String?
  status              ServiceProviderRequestStatus @default(SUBMITTED)
  readinessOnly       Boolean                      @default(false)
  adminNote           String?
  customerUpdateNote  String?
  assignmentNote      String?
  assignedAt          DateTime?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  customer            CustomerProfile              @relation(fields: [customerId], references: [id])
  assignedProvider    ServiceProvider?             @relation(fields: [assignedProviderId], references: [id])
  assignedByAdmin     User?                        @relation("ServiceProviderRequestAssignedBy", fields: [assignedByAdminId], references: [id])
  serviceAddress      Address                      @relation("ServiceRequestAddress", fields: [serviceAddressId], references: [id])

  @@index([customerId, createdAt])
  @@index([assignedProviderId, status])
  @@index([serviceType, status, createdAt])
  @@index([status, createdAt])
  @@map("service_provider_requests")
}

model ServiceProvider {
  id                  String                      @id @default(uuid()) @db.Uuid
  sourceApplicationId String?                     @unique @db.Uuid
  providerCode        String                      @unique
  fullName            String
  businessName        String?
  serviceType         ServiceProviderType
  phoneNumber         String
  email               String?
  city                String
  state               String
  serviceAreas        Json?
  status              ServiceProviderStatus       @default(PENDING_REVIEW)
  readinessOnly       Boolean                     @default(false)
  notes               String?
  verificationNote    String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  sourceApplication   ServiceProviderApplication? @relation("ServiceProviderApplicationConvertedProvider", fields: [sourceApplicationId], references: [id])
  assignedRequests    ServiceProviderRequest[]

  @@index([serviceType, status])
  @@index([city, state])
  @@index([phoneNumber])
  @@map("service_providers")
}

model ServiceProviderApplication {
  id                   String                           @id @default(uuid()) @db.Uuid
  applicationReference String                           @unique
  fullName             String
  businessName         String?
  serviceType          ServiceProviderType
  phoneNumber          String
  email                String?
  city                 String
  state                String
  serviceAreas         Json?
  address              String?
  experienceSummary    String?
  toolsOrEquipment     String?
  availability         String?
  identificationType   String?
  identificationNumber String?
  status               ServiceProviderApplicationStatus @default(SUBMITTED)
  reviewNote           String?
  submittedAt          DateTime                         @default(now())
  reviewedAt           DateTime?
  reviewedByAdminId    String?                          @db.Uuid
  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt
  reviewedByAdmin      User?                            @relation("ServiceProviderApplicationReviewedBy", fields: [reviewedByAdminId], references: [id])
  convertedProvider    ServiceProvider?                 @relation("ServiceProviderApplicationConvertedProvider")

  @@index([status, submittedAt])
  @@index([serviceType, status])
  @@index([city, state])
  @@index([phoneNumber])
  @@map("service_provider_applications")
}

model SmeServicesPilotReadinessItem {
  id               String    @id @default(uuid()) @db.Uuid
  key              String    @unique
  category         String
  label            String
  description      String
  sortOrder        Int
  isRequired       Boolean   @default(true)
  isCompleted      Boolean   @default(false)
  note             String?
  updatedByAdminId String?   @db.Uuid
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([category, sortOrder])
  @@index([isRequired, isCompleted])
  @@map("sme_services_pilot_readiness_items")
