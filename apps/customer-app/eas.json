{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "customer-staging": {
      "distribution": "internal",
      "channel": "customer-staging",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "https://karigo-8htn.onrender.com/api/v1"
      }
    },
    "customer-staging-ios-simulator": {
      "distribution": "internal",
      "channel": "customer-staging",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "https://karigo-8htn.onrender.com/api/v1"
      }
    },
    "customer-production": {
      "distribution": "store",
      "channel": "customer-production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://karigo-8htn.onrender.com/api/v1"
      }
    }
  },
  "submit": {}
}
